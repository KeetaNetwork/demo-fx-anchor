{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowJs": true,
		"checkJs": true,

		"skipLibCheck": true,

		"paths": {
			"@/api/*": ["./apps/api/src/*"]
		},

		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,

		"declaration": true,
		"declarationMap": true,

		// Linting
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true
	},
	"exclude": ["node_modules", "dist", "build", "vendor"]
}
